.phase-grid {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}
.phase-tile {
  flex: 1;
  text-align: center;
  background: #0a1628;
  border: 1rpx solid #1f3a5f;
  border-radius: 12rpx;
  padding: 16rpx 8rpx;
}
.phase-tile:active { opacity: 0.7; }
.phase-tile-on {
  background: rgba(240, 180, 41, 0.1);
  border-color: #f0b429;
}
.phase-tile-emoji { font-size: 36rpx; }
.phase-tile-name {
  font-size: 22rpx;
  color: #cbd5e1;
  margin-top: 4rpx;
}

.risk-row { display: flex; gap: 12rpx; margin-top: 16rpx; }
.risk-tile {
  flex: 1;
  background: #0a1628;
  border: 1rpx solid #1f3a5f;
  border-radius: 12rpx;
  padding: 20rpx 12rpx;
  text-align: center;
}
.risk-tile:active { opacity: 0.7; }
.risk-tile-on {
  background: rgba(240, 180, 41, 0.1);
  border-color: #f0b429;
}
.risk-emoji { font-size: 32rpx; }
.risk-name {
  font-size: 26rpx;
  color: #f8fafc;
  font-weight: 600;
  margin-top: 4rpx;
}
.risk-desc {
  font-size: 20rpx;
  color: #94a3b8;
  margin-top: 4rpx;
  line-height: 1.4;
}

.bar-list { margin-top: 16rpx; }
.bar-row { margin-bottom: 20rpx; }
.bar-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  margin-bottom: 6rpx;
}
.bar-dot {
  display: inline-block;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}
.bar-name {
  flex: 1;
  color: #e8edf5;
}
.bar-pct {
  color: #f0b429;
  font-weight: 700;
  font-size: 28rpx;
}
.bar-track {
  height: 16rpx;
  background: #0a1628;
  border-radius: 8rpx;
  overflow: hidden;
}
.bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s;
}

.phase-section {
  background: #0a1628;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}
.phase-section-h {
  font-size: 24rpx;
  font-weight: 600;
  color: #cbd5e1;
  margin-bottom: 8rpx;
}
.phase-section-body {
  font-size: 26rpx;
  color: #e8edf5;
  line-height: 1.7;
}

.row-tr { display: flex; padding: 14rpx 0; }
.row-td { flex: 1; font-size: 26rpx; }
