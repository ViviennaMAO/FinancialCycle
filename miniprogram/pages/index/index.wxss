.chapter-item:active { opacity: 0.7; }

.chapter-h-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 4rpx;
}
.chapter-badge {
  background: #1f3a5f;
  color: #f0b429;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.chapter-oneline {
  color: #cbd5e1;
  font-size: 24rpx;
  margin-top: 12rpx;
  line-height: 1.55;
}

.fred-card { border-color: #22c55e; }

.fred-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 16rpx -8rpx 0;
}
.fred-cell {
  width: 50%;
  padding: 12rpx 8rpx;
  box-sizing: border-box;
}
.fred-label {
  font-size: 22rpx;
  color: #94a3b8;
}
.fred-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #f8fafc;
  margin-top: 4rpx;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}
.fred-unit {
  font-size: 22rpx;
  color: #7a8aa3;
  font-weight: 400;
}
.fred-delta {
  font-size: 20rpx;
  font-weight: 600;
  margin-left: 8rpx;
}
.fred-delta.up   { color: #22c55e; }
.fred-delta.down { color: #ef4444; }
.fred-note {
  font-size: 20rpx;
  color: #7a8aa3;
  margin-top: 4rpx;
  line-height: 1.4;
}
