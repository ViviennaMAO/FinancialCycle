.option {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: #0a1628;
  border: 1rpx solid #1f3a5f;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 16rpx;
  transition: all 0.2s;
}
.option:active { opacity: 0.7; }

.opt-letter {
  display: inline-block;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #1f3a5f;
  color: #f0b429;
  text-align: center;
  line-height: 40rpx;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.opt-text {
  flex: 1;
  color: #e8edf5;
  font-size: 26rpx;
  line-height: 1.5;
}

.option-correct { background: rgba(34, 197, 94, 0.15); border-color: #22c55e; }
.option-correct .opt-letter { background: #22c55e; color: #0a1628; }

.option-wrong { background: rgba(239, 68, 68, 0.15); border-color: #ef4444; }
.option-wrong .opt-letter { background: #ef4444; color: #fff; }

.option-reveal { border-color: #22c55e; }
.option-reveal .opt-letter { background: #22c55e; color: #0a1628; }
